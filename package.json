{
  "name": "locallife-os",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @locallife/web",
    "build:web": "npm run build --workspace @locallife/web",
    "lint:web": "npm run lint --workspace @locallife/web",
    "typecheck:web": "npm run typecheck --workspace @locallife/web",
    "test:web": "npm run test --workspace @locallife/web",
    "test:e2e:web": "node tests/e2e/frontend-smoke.mjs",
    "generate:api-types": "openapi-typescript packages/shared-types/src/openapi.json -o packages/shared-types/src/openapi.ts"
  },
  "devDependencies": {
    "openapi-typescript": "7.13.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
